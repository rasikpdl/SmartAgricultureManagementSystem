<%- include('layout') %>

<h2 class="mb-3">Sensors</h2>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<!-- Step 1 & 2: Farm → Field filter -->
<form method="GET" action="/sensors" class="mb-4">
  <div class="row g-2 align-items-end">
    <div class="col-md-4">
      <label for="farm_id" class="form-label fw-bold">Select Farm:</label>
      <select name="farm_id" id="farm_id" class="form-select"
              onchange="this.form.field_id.value=''; this.form.submit()">
        <option value="">-- Choose a Farm --</option>
        <% farms.forEach(f => { %>
          <option value="<%= f.farm_id %>" <%= selectedFarmId == f.farm_id ? 'selected' : '' %>>
            <%= f.farm_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-4">
      <label for="field_id" class="form-label fw-bold">Select Field:</label>
      <select name="field_id" id="field_id" class="form-select"
              onchange="this.form.submit()" <%= !selectedFarmId ? 'disabled' : '' %>>
        <option value="">-- Choose a Field --</option>
        <% fields.forEach(f => { %>
          <option value="<%= f.field_id %>" <%= selectedFieldId == f.field_id ? 'selected' : '' %>>
            <%= f.field_name %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>
</form>

<% if (selectedFieldId) { %>
  <table class="table table-bordered table-hover table-sm">
    <thead class="table-warning">
      <tr>
        <th>ID</th><th>Sensor Type</th><th>Installed Date</th><th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (sensors.length === 0) { %>
        <tr><td colspan="4" class="text-center text-muted">No sensors yet for this field. Add one below.</td></tr>
      <% } %>
      <% sensors.forEach(r => { %>
      <tr>
        <td><%= r.sensor_id %></td>
        <td><%= r.sensor_type %></td>
        <td><%= r.installed_date ? new Date(r.installed_date).toISOString().split('T')[0] : '' %></td>
        <td>
          <form method="POST" action="/sensors/delete" style="display:inline">
            <input type="hidden" name="sensor_id" value="<%= r.sensor_id %>">
            <input type="hidden" name="farm_id"   value="<%= selectedFarmId %>">
            <input type="hidden" name="field_id"  value="<%= selectedFieldId %>">
            <button class="btn btn-sm btn-danger"
                    onclick="return confirm('Delete this sensor?')">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <hr>
  <h4>Add a Sensor</h4>
  <form method="POST" action="/sensors/add" class="row g-2 mt-1">
    <input type="hidden" name="farm_id"  value="<%= selectedFarmId %>">
    <input type="hidden" name="field_id" value="<%= selectedFieldId %>">
    <div class="col-md-4">
      <input class="form-control" name="sensor_type" placeholder="Sensor Type (e.g. Temperature)" required>
    </div>
    <div class="col-md-3">
      <input class="form-control" type="date" name="installed_date" title="Installed Date">
    </div>
    <div class="col-md-2">
      <button class="btn btn-success w-100">Add</button>
    </div>
  </form>

<% } else if (selectedFarmId) { %>
  <div class="alert alert-info">Please select a field to view its sensors.</div>
<% } else { %>
  <div class="alert alert-info">Please select a farm first.</div>
<% } %>

</div></body></html>