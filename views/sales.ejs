<%- include('layout') %>

<h2 class="mb-3">Sales</h2>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<!-- Step 1 & 2: Farm → Field filter -->
<form method="GET" action="/sales" class="mb-4">
  <div class="row g-2 align-items-end">
    <div class="col-md-4">
      <label for="farm_id" class="form-label fw-bold">Select Farm:</label>
      <select name="farm_id" id="farm_id" class="form-select"
              onchange="this.form.field_id.value=''; this.form.submit()">
        <option value="">-- Choose a Farm --</option>
        <% farms.forEach(f => { %>
          <option value="<%= f.farm_id %>" <%= selectedFarmId == f.farm_id ? 'selected' : '' %>>
            <%= f.farm_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-4">
      <label for="field_id" class="form-label fw-bold">Select Field:</label>
      <select name="field_id" id="field_id" class="form-select"
              onchange="this.form.submit()"
              <%= !selectedFarmId ? 'disabled' : '' %>>
        <option value="">-- Choose a Field --</option>
        <% fields.forEach(f => { %>
          <option value="<%= f.field_id %>" <%= selectedFieldId == f.field_id ? 'selected' : '' %>>
            <%= f.field_name %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>
</form>

<% if (selectedFieldId) { %>
  <table class="table table-bordered table-hover table-sm">
    <thead class="table-success">
      <tr>
        <th>ID</th><th>Crop</th><th>Harvest Date</th><th>Buyer Name</th>
        <th>Quantity Sold (kg)</th><th>Price Per kg ($)</th><th>Sale Date</th><th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="8" class="text-center text-muted">No sales recorded yet for this field. Add one below.</td></tr>
      <% } %>
      <% rows.forEach(r => { %>
      <tr>
        <td><%= r.sale_id %></td>
        <td><%= r.crop_name %></td>
        <td><%= r.harvest_date ? new Date(r.harvest_date).toLocaleDateString() : '' %></td>
        <td><%= r.buyer_name %></td>
        <td><%= r.quantity_sold_kg %></td>
        <td>$<%= r.price_per_kg %></td>
        <td><%= r.sale_date ? new Date(r.sale_date).toLocaleDateString() : '' %></td>
        <td>
          <form method="POST" action="/sales/delete" style="display:inline">
            <input type="hidden" name="sale_id"  value="<%= r.sale_id %>">
            <input type="hidden" name="farm_id"  value="<%= selectedFarmId %>">
            <input type="hidden" name="field_id" value="<%= selectedFieldId %>">
            <button class="btn btn-sm btn-danger"
              onclick="return confirm('Delete this sale record?')">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <hr>
  <h4>Log a Sale</h4>
  <form method="POST" action="/sales/add" class="row g-2 mt-1">
    <input type="hidden" name="farm_id"  value="<%= selectedFarmId %>">
    <input type="hidden" name="field_id" value="<%= selectedFieldId %>">
    <div class="col-md-3">
      <select class="form-select" name="harvest_id" required>
        <option value="" disabled selected>Select a Harvest...</option>
        <% harvests.forEach(h => { %>
          <option value="<%= h.harvest_id %>">
            <%= h.crop_name %> - <%= h.harvest_date ? new Date(h.harvest_date).toLocaleDateString() : '' %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <input class="form-control" name="buyer_name" placeholder="Buyer Name">
    </div>
    <div class="col-md-2">
      <input class="form-control" name="quantity_sold_kg" placeholder="Quantity (kg)"
        type="number" step="0.01" min="0" required>
    </div>
    <div class="col-md-2">
      <input class="form-control" name="price_per_kg" placeholder="Price/kg ($)"
        type="number" step="0.01" min="0" required>
    </div>
    <div class="col-md-2">
      <input class="form-control" name="sale_date" type="date" required>
    </div>
    <div class="col-md-1">
      <button class="btn btn-success w-100">Add</button>
    </div>
  </form>

<% } else if (selectedFarmId) { %>
  <div class="alert alert-info">Please select a field to view its sales.</div>
<% } else { %>
  <div class="alert alert-info">Please select a farm first.</div>
<% } %>

</div></body></html>
