<%- include('layout') %>

<h2 class="mb-3">Diseases & Pests</h2>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<!-- Step 1, 2 & 3: Farm → Field → Crop filter -->
<form method="GET" action="/diseases" class="mb-4">
  <div class="row g-2 align-items-end">
    <div class="col-md-3">
      <label for="farm_id" class="form-label fw-bold">Select Farm:</label>
      <select name="farm_id" id="farm_id" class="form-select"
              onchange="this.form.field_id.value=''; this.form.crop_id.value=''; this.form.submit()">
        <option value="">-- Choose a Farm --</option>
        <% farms.forEach(f => { %>
          <option value="<%= f.farm_id %>" <%= selectedFarmId == f.farm_id ? 'selected' : '' %>>
            <%= f.farm_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label for="field_id" class="form-label fw-bold">Select Field:</label>
      <select name="field_id" id="field_id" class="form-select"
              onchange="this.form.crop_id.value=''; this.form.submit()"
              <%= !selectedFarmId ? 'disabled' : '' %>>
        <option value="">-- Choose a Field --</option>
        <% fields.forEach(f => { %>
          <option value="<%= f.field_id %>" <%= selectedFieldId == f.field_id ? 'selected' : '' %>>
            <%= f.field_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label for="crop_id" class="form-label fw-bold">Select Crop:</label>
      <select name="crop_id" id="crop_id" class="form-select"
              onchange="this.form.submit()"
              <%= !selectedFieldId ? 'disabled' : '' %>>
        <option value="">-- Choose a Crop --</option>
        <% crops.forEach(c => { %>
          <option value="<%= c.crop_id %>" <%= selectedCropId == c.crop_id ? 'selected' : '' %>>
            <%= c.crop_name %><%= c.variety ? ' (' + c.variety + ')' : '' %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>
</form>

<% if (selectedCropId) { %>
  <table class="table table-bordered table-hover table-sm">
    <thead class="table-success">
      <tr>
        <th>ID</th><th>Disease Name</th>
        <th>Date Detected</th><th>Severity</th><th>Treatment Notes</th><th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="6" class="text-center text-muted">No diseases recorded yet for this crop. Add one below.</td></tr>
      <% } %>
      <% rows.forEach(r => { %>
      <tr>
        <td><%= r.disease_id %></td>
        <td><%= r.disease_name %></td>
        <td>
          <%= r.detected_date ? new Date(r.detected_date).toLocaleDateString() : '' %>
        </td>
        <td><%= r.severity %></td>
        <td><%= r.treatment_notes %></td>
        <td>
          <form method="POST" action="/diseases/delete" style="display:inline">
            <input type="hidden" name="disease_id" value="<%= r.disease_id %>">
            <input type="hidden" name="farm_id"        value="<%= selectedFarmId %>">
            <input type="hidden" name="field_id"       value="<%= selectedFieldId %>">
            <input type="hidden" name="crop_id"        value="<%= selectedCropId %>">
            <button class="btn btn-sm btn-danger"
              onclick="return confirm('Delete this disease record?')">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <hr>
  <h4>Log a Disease</h4>
  <form method="POST" action="/diseases/add" class="row g-2 mt-1">
    <input type="hidden" name="farm_id"  value="<%= selectedFarmId %>">
    <input type="hidden" name="field_id" value="<%= selectedFieldId %>">
    <input type="hidden" name="crop_id"  value="<%= selectedCropId %>">
    
    <div class="col-md-3">
      <input class="form-control" name="disease_name" placeholder="Disease Name" required>
    </div>
    <div class="col-md-2">
      <input class="form-control" name="detected_date" type="date" required>
    </div>
    <div class="col-md-2">
      <select class="form-select" name="severity">
        <option value="Low">Low</option>
        <option value="Medium">Medium</option>
        <option value="High">High</option>
        <option value="Critical">Critical</option>
      </select>
    </div>
    <div class="col-md-4">
      <input class="form-control" name="treatment_notes" placeholder="Treatment Notes">
    </div>
    <div class="col-md-1">
      <button class="btn btn-success w-100">Add</button>
    </div>
  </form>

<% } else if (selectedFieldId) { %>
  <div class="alert alert-info">Please select a crop to view its disease records.</div>
<% } else if (selectedFarmId) { %>
  <div class="alert alert-info">Please select a field next.</div>
<% } else { %>
  <div class="alert alert-info">Please select a farm first.</div>
<% } %>

</div></body></html>
